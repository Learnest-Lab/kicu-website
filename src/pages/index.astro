---
import Layout from '../layouts/Layout.astro';

const APP_STORE = 'https://apps.apple.com/my/app/id6758668352';
const GOOGLE_PLAY = 'https://play.google.com/store/apps/details?id=com.kicu.tax';
const PRIVACY = 'https://learnest-lab.github.io/kicu-public/privacy.html';
const TERMS = 'https://learnest-lab.github.io/kicu-public/terms.html';
const CONTACT = 'mailto:learnestlab@outlook.com';

const faqs = [
  { q: 'Is KICU approved by LHDN?', a: "KICU isn't an official LHDN product. We're a tool that helps you organise your tax-relief receipts using LHDN's published relief categories and limits. When it's time to file, you still submit through MyTax / e-Filing as usual. We just make the prep part painless." },
  { q: 'What if the app reads my receipt wrong?', a: "Every scanned receipt is reviewable. Tap any entry to edit the merchant, amount, or category before it counts toward your claims. We'd rather have you in control." },
  { q: 'How does KICU keep my data safe?', a: "Your receipts and tax details are stored on your device. We never sell your data, and your tax info is yours, full stop. You can export everything or delete your account any time." },
  { q: 'Is it really free?', a: "The core features, snap, categorise, and track limits for one tax year, are free forever. We're working on a KICU Pro tier with multi-year history, receipt PDF export, and priority support. No dark patterns, no surprise bills." },
  { q: 'Can I use KICU for freelance or side-income tax?', a: "KICU 1.0 is focused on salaried employees claiming personal reliefs. Business expense tracking is on the roadmap. Tell us first by tapping a download button above." },
  { q: 'Available in Bahasa Malaysia?', a: "Yes! Toggle language in Settings. We built KICU bilingual from day one because nak cakap tax dalam BM memang lagi senang." },
];

const steps = [
  { n: '01', t: 'Snap your receipt', d: 'After any tax-deductible purchase, like books, a doctor visit, or sports gear, just snap a photo. KICU reads it in seconds.', img: '/images/screen-receipt.png', alt: 'A captured receipt sorted into its relief category' },
  { n: '02', t: 'We sort it for you', d: 'Every receipt drops into the right LHDN category automatically. No spreadsheets. No second-guessing.', img: '/images/screen-relief.png', alt: 'Relief categories with live progress against each limit' },
  { n: '03', t: 'File with confidence', d: 'Come filing season, get a clean Form BE summary for LHDN e-Filing. Review, copy into MyTax, done.', img: '/images/screen-formbe.png', alt: 'Form BE summary ready to copy into MyTax' },
];
---

<Layout>
  <!-- ============ NAV ============ -->
  <nav class="nav" id="nav">
    <a href="#top" class="wordmark" style="text-decoration:none">KICU<span class="spark">&#10022;</span></a>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#how">How it works</a>
      <a href="#faq">FAQ</a>
      <a href="#download" class="btn-get"><span class="spark" style="font-size:12px">&#10022;</span> Get KICU</a>
    </div>
  </nav>

  <!-- ============ HERO (Bold) ============ -->
  <section class="hero" id="top">
    <div class="sparkfield" data-count="30"></div>
    <div class="hero-inner">
      <span class="badge-pill"><span class="spark" style="font-size:12px">&#10022;</span> KEEP IT YAKIN &middot; BUILT IN MALAYSIA</span>
      <h1>Musim cukai tak perlu <span class="hl">kecoh lagi.<svg viewBox="0 0 100 20" preserveAspectRatio="none"><path d="M2 14 Q 25 4, 50 12 T 98 8" stroke="#D4F419" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.9"/></svg></span></h1>
      <p class="hero-sub">Snap receipt masa beli. KICU akan sort, track, dan sediakan semua. Filing day jadi 10 minit je.</p>
      <div class="badges">
        <a href={APP_STORE} target="_blank" rel="noopener noreferrer"><img src="/images/app-store-badge.svg" alt="Download on the App Store" width="180" height="60" /></a>
        <a href={GOOGLE_PLAY} target="_blank" rel="noopener noreferrer"><img src="/images/google-play-badge.svg" alt="Get it on Google Play" width="180" height="60" /></a>
      </div>

      <div class="phone-stage">
        <!-- floating chips (honest: streak chip replaced with Tax-Ready) -->
        <div class="chip chip-saved">
          <span class="ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></span>
          <span><span class="lab">Saved</span><br/><span class="val">MPH &middot; RM 142</span></span>
        </div>
        <div class="chip chip-cat">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#D4F419" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          <span class="val">Books &amp; Education</span>
        </div>
        <div class="chip chip-limit">
          <div class="row"><span>Lifestyle</span><span>88%</span></div>
          <div class="bar"><i></i></div>
        </div>
        <div class="chip chip-ready">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#D4F419" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          <span class="val">Tax-Ready</span>
        </div>
        <!-- REAL home screenshot -->
        <div class="phone"><img src="/images/screen-home.png" alt="KICU home screen showing tax relief tracked for the year" /></div>
      </div>
    </div>
  </section>

  <!-- ============ FEATURES (cream) ============ -->
  <section class="section features" id="features">
    <div class="section-head">
      <span class="eyebrow"><span class="spark" style="font-size:10px">&#10022;</span> Features</span>
      <h2 class="section-h2">Less kecoh.<br/><span style="color:var(--blue)">More clarity.</span></h2>
      <p class="section-sub" style="color:var(--muted)">Four things KICU does brilliantly. Built for working Malaysians who just want tax season to feel manageable.</p>
    </div>
    <div class="feat-grid">
      <div class="feat-card">
        <div class="feat-icon" style="background:rgba(212,244,25,0.16);color:#A6B800"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3.5"/></svg></div>
        <h3>Snap it</h3>
        <p>Point your camera at a receipt. We read the merchant, amount, and date in seconds.</p>
        <div class="feat-spark spark">&#10022;</div>
      </div>
      <div class="feat-card">
        <div class="feat-icon" style="background:rgba(232,153,40,0.14);color:var(--orange)"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7.5" cy="7.5" r="1.5"/></svg></div>
        <h3>Auto-categorize</h3>
        <p>Every receipt lands in the right LHDN relief category. Books, Medical, Lifestyle, and more.</p>
        <div class="feat-spark spark">&#10022;</div>
      </div>
      <div class="feat-card">
        <div class="feat-icon" style="background:rgba(21,125,236,0.10);color:var(--blue)"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l3-3 3 3 5-6"/></svg></div>
        <h3>Track your limits</h3>
        <p>Watch your progress against each RM cap. Gentle nudges before you hit the ceiling.</p>
        <div class="feat-spark spark">&#10022;</div>
      </div>
      <div class="feat-card">
        <div class="feat-icon" style="background:rgba(212,244,25,0.16);color:#A6B800"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h6"/></svg></div>
        <h3>Export for filing</h3>
        <p>When LHDN e-Filing opens, export a tidy summary. Review, submit, done.</p>
        <div class="feat-spark spark">&#10022;</div>
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS (navy) ============ -->
  <section class="section how" id="how">
    <div class="sparkfield" data-count="20"></div>
    <div class="section-head">
      <span class="eyebrow"><span class="spark" style="font-size:10px">&#10022;</span> How it works</span>
      <h2 class="section-h2">Three steps to filing season zen</h2>
      <p class="section-sub" style="color:rgba(255,255,255,0.7)">No spreadsheets. No last-minute scramble. Just snap, sort, submit.</p>
    </div>
    <div class="how-steps">
      {steps.map((s) => (
        <div class="step">
          <div class="step-text">
            <div class="step-num">{s.n}</div>
            <h3 class="step-title">{s.t}</h3>
            <p class="step-desc">{s.d}</p>
          </div>
          <div class="step-phone">
            <div class="phone"><img src={s.img} alt={s.alt} /></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ FAQ (cream) ============ -->
  <section class="section faq" id="faq">
    <div class="section-head">
      <span class="eyebrow"><span class="spark" style="font-size:10px">&#10022;</span> FAQ</span>
      <h2 class="section-h2" style="font-size:clamp(32px,4.5vw,48px)">Questions? We got you.</h2>
    </div>
    <div class="faq-list">
      {faqs.map((f, i) => (
        <details class="faq-item" open={i === 0}>
          <summary>{f.q}<span class="faq-toggle">+</span></summary>
          <div class="faq-a">{f.a}</div>
        </details>
      ))}
    </div>
  </section>

  <!-- ============ DOWNLOAD (navy) ============ -->
  <section class="section download" id="download">
    <div class="sparkfield" data-count="24"></div>
    <div class="dl-inner">
      <div class="big-spark">&#10022;</div>
      <h2>Ready to stop the<br/>tax-season kecoh?</h2>
      <p>Free to download. Free forever for the essentials. Your first receipt takes 10 seconds.</p>
      <div class="badges">
        <a href={APP_STORE} target="_blank" rel="noopener noreferrer"><img src="/images/app-store-badge.svg" alt="Download on the App Store" width="180" height="60" /></a>
        <a href={GOOGLE_PLAY} target="_blank" rel="noopener noreferrer"><img src="/images/google-play-badge.svg" alt="Get it on Google Play" width="180" height="60" /></a>
      </div>
      <div class="fineprint">Works on iOS 15+ and Android 10+ &middot; Available in English &amp; Bahasa Malaysia</div>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer class="footer">
    <div class="foot-grid">
      <div>
        <span class="wordmark">KICU<span class="spark">&#10022;</span></span>
        <div class="foot-tag">KIRA CUKAI</div>
        <p class="foot-blurb">Made in Malaysia for Malaysians. Helping working professionals keep tax relief on track, one receipt at a time.</p>
      </div>
      <div class="foot-col">
        <h4>Product</h4>
        <a href="#features">Features</a>
        <a href="#how">How it works</a>
        <a href="#download">Download</a>
      </div>
      <div class="foot-col">
        <h4>Company</h4>
        <a href={CONTACT}>Contact</a>
      </div>
      <div class="foot-col">
        <h4>Legal</h4>
        <a href={PRIVACY} target="_blank" rel="noopener noreferrer">Privacy</a>
        <a href={TERMS} target="_blank" rel="noopener noreferrer">Terms</a>
        <a href={TERMS} target="_blank" rel="noopener noreferrer">LHDN disclaimer</a>
      </div>
    </div>
    <div class="foot-bottom">
      <div>&copy; 2026 Learnest Lab Sdn Bhd. All rights reserved.</div>
      <div>Not affiliated with LHDN. Always verify reliefs on MyTax.</div>
    </div>
  </footer>

  <script is:inline>
    // Nav background on scroll
    const nav = document.getElementById('nav');
    const onScroll = () => { if (nav) nav.classList.toggle('scrolled', window.scrollY > 40); };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Scatter sparks into each .sparkfield
    document.querySelectorAll('.sparkfield').forEach((field) => {
      const count = parseInt(field.getAttribute('data-count') || '16', 10);
      for (let i = 0; i < count; i++) {
        const s = document.createElement('span');
        s.className = 'sf';
        s.textContent = '✦';
        const size = 8 + Math.random() * 28;
        const op = 0.15 + Math.random() * 0.5;
        s.style.left = (Math.random() * 100) + '%';
        s.style.top = (Math.random() * 100) + '%';
        s.style.fontSize = size + 'px';
        s.style.setProperty('--o', op.toFixed(2));
        s.style.opacity = op.toFixed(2);
        s.style.transform = 'rotate(' + (15 + Math.random() * 12) + 'deg)';
        s.style.filter = 'drop-shadow(0 0 ' + (size * 0.4) + 'px rgba(212,244,25,0.55))';
        s.style.animation = 'sparkPulse 3.2s ease-in-out ' + (Math.random() * 3).toFixed(2) + 's infinite';
        field.appendChild(s);
      }
    });
  </script>
</Layout>
